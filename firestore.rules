rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Members can read all profiles; only write their own
    match /users/{uid} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == uid;
    }

    // Allowlist: any authenticated user can read (needed to verify membership on sign-in)
    match /allowedEmails/{email} {
      allow read: if request.auth != null;
    }

    // Announcements: any member can read and create
    // Author can update/delete anything; any member can update only likedBy and commentCount
    match /announcements/{id} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null && (
        request.auth.uid == resource.data.authorId
        || request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likedBy', 'commentCount'])
      );
      allow delete: if request.auth != null
        && request.auth.uid == resource.data.authorId;
    }

    // Comments: any member can read and post; only the comment author can edit or delete
    match /announcements/{id}/comments/{commentId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null
        && request.auth.uid == resource.data.authorId;
    }

    // Gallery: any member can read and upload; only uploader can delete
    match /gallery/{id} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null
        && request.auth.uid == resource.data.uploadedBy;
    }
  }
}
